{
  "$schema": "[https://json-schema.org/draft/2020-12/schema](https://json-schema.org/draft/2020-12/schema)",
  "title": "BOUNDARYCAM Boundary Frame",
  "type": "object",
  "required": [
    "id",
    "title",
    "actor",
    "action",
    "target",
    "authority",
    "execution",
    "evidence",
    "replay",
    "recognition",
    "recourse",
    "closure",
    "status",
    "question"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^BCAM-[0-9]{3}$"
    },
    "title": {
      "type": "string"
    },
    "actor": {
      "type": "string"
    },
    "action": {
      "type": "string"
    },
    "target": {
      "type": "string"
    },
    "authority": {
      "type": "string"
    },
    "execution": {
      "type": "string"
    },
    "evidence": {
      "type": "string"
    },
    "replay": {
      "type": "string"
    },
    "recognition": {
      "type": "string"
    },
    "recourse": {
      "type": "string"
    },
    "closure": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "BOUNDARY INCOMPLETE",
        "CONTROLLED",
        "CLOSED"
      ]
    },
    "question": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
